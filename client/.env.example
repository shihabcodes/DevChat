# Client Environment Variables
#
# Local dev: leave NEXT_PUBLIC_API_URL pointing at the local Express server.
# Production: set this to your Railway/Render backend URL, e.g.
#   NEXT_PUBLIC_API_URL=https://devchat-api.up.railway.app/api
#
# The Next.js rewrite in next.config.js will also handle /api/* on
# Vercel, so you can leave it empty there if you prefer proxying.

NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Public Google OAuth Web client ID. Get one at
# https://console.cloud.google.com/apis/credentials
# (Authorized JavaScript origins must include your dev + prod URLs.)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
