# --- Server ---
PORT=5001
NODE_ENV=development

# --- Database ---
# For local dev: mongodb://127.0.0.1:27017/devchat
# For prod: use MongoDB Atlas. URL-encode any special chars in the password.
MONGODB_URI=mongodb://127.0.0.1:27017/devchat

# --- Auth ---
# MUST be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# In production, the server will REFUSE to boot if this still contains
# "change", "your_", "changeme", "placeholder", or "example".
JWT_SECRET=replace-me-with-a-real-64-byte-secret-please

# 32+ char secret used to AES-256-GCM encrypt each user's OpenAI
# API key at rest. Generate the same way as JWT_SECRET.
OPENAI_KEY_ENCRYPTION_SECRET=replace-me-with-a-real-32-byte-secret

# --- Google OAuth ---
# Create a Web OAuth client at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000 and your production frontend URL to Authorized JS Origins.
GOOGLE_CLIENT_ID=

# --- CORS ---
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000

# --- Misc ---
# How long ephemeral demo workspaces live before being purged (hours).
DEMO_TTL_HOURS=2
